
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the Campus Hub application.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user, matching the Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "dni": {
            "type": "string",
            "description": "The user's national identity document number."
        },
        "role": {
          "type": "string",
          "description": "Role of the user in the system.",
          "enum": ["student", "professor", "admin", "staff"]
        },
        "status": {
          "type": "string",
          "description": "Account status.",
          "enum": ["active", "inactive"]
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "profilePicture": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "The user's date of birth."
        },
        "address": {
            "type": "string",
            "description": "The user's physical address."
        },
        "phone": {
            "type": "string",
            "description": "The user's phone number."
        },
        "cvUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to the user's CV/Resume file."
        },
        "professionalTitle": {
          "type": "string",
          "description": "Professional title or headline extracted from CV."
        },
        "summary": {
          "type": "string",
          "description": "Professional summary or bio extracted from CV."
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of technical and soft skills."
        },
        "experience": {
          "type": "string",
          "description": "Formatted work experience history."
        },
        "education": {
          "type": "string",
          "description": "Formatted education history."
        },
        "bio": {
          "type": "string",
          "description": "A short professional biography, mainly for professors."
        },
        "specialization": {
            "type": "array",
            "items": { "type": "string" },
            "description": "An array of specializations or areas of expertise for professors."
        },
        "officeHours": {
            "type": "string",
            "description": "A string describing office hours for professors (e.g., 'Mon/Wed 10-12')."
        },
        "programId": {
          "type": "string",
          "description": "The ID of the university program the student is enrolled in."
        }
      },
      "required": ["uid", "email", "role", "firstName", "lastName", "dni"]
    },
    "WellnessResource": {
      "title": "WellnessResource",
      "type": "object",
      "description": "Informational resources for students.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string", format: "uri" },
        "category": { "type": "string" }
      },
      "required": ["title", "url"]
    },
    "WellnessServiceType": {
      "title": "WellnessServiceType",
      "type": "object",
      "description": "Types of wellness services available and their assigned staff.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", description: "Example: Psychological Orientation" },
        "staffId": { "type": "string", description: "UID of the staff member responsible for this service." },
        "staffName": { "type": "string" }
      },
      "required": ["name", "staffId"]
    },
    "WellnessAppointment": {
      "title": "WellnessAppointment",
      "description": "Represents a wellness service appointment.",
      "type": "object",
      "properties": {
        "serviceId": { "type": "string" },
        "userId": { "type": "string", description: "UID of the user requesting the service." },
        "serviceName": { "type": "string" },
        "assignedStaffId": { "type": "string", description: "UID of the person assigned to handle this." },
        "status": { "type": "string", "enum": ["requested", "scheduled", "completed", "canceled"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["userId", "serviceName", "status", "requestedAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": {
      "/wellness_resources/{resourceId}": {
        "schema": { "$ref": "#/entities/WellnessResource" },
        "description": "Stores resources for support section."
      },
      "/wellness_service_config/{serviceId}": {
        "schema": { "$ref": "#/entities/WellnessServiceType" },
        "description": "Configuration of available services and assigned personnel."
      },
      "/wellness_services/{serviceId}": {
        "schema": { "$ref": "#/entities/WellnessAppointment" },
        "description": "Stores appointments for wellness services."
      }
    }
  }
}
