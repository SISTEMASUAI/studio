
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to simplify rule logic
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isOneOfRoles(roles) {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return userRole in roles;
    }

    function isInstructor(courseId) {
      return get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;
    }

    // User Profiles: Readable by any authenticated user, but only writable by the owner.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      // Financial Info: Accessible only by the student and admins.
      match /financialInfo/{infoId} {
        allow read, write: if isOwner(userId) || isRole('admin');
      }

      // Scholarships: Accessible by the student and admins.
      match /scholarships/{scholarshipId} {
        allow read, write: if isOwner(userId) || isRole('admin');
      }

      // Job Applications: Accessible only by the student and admins.
      match /job_applications/{applicationId} {
        allow read: if isOwner(userId) || isRole('admin');
        // Students can create/update their own applications. Admins can update any.
        allow write: if isOwner(userId) || isRole('admin');
      }
    }

    // University Programs & Faculties: Readable by any signed-in user, writable by admins.
    match /programs/{programId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }
    
    match /faculties/{facultyId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }

    // Intranet Posts: Readable by all, writable only by the author or admins.
    match /intranet_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.authorId == request.auth.uid || isRole('admin'));
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isRole('admin'));
    }

    // Courses: Readable by all, but only the instructor or admin can manage them.
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.instructorId == request.auth.uid || isRole('admin'));
      allow update, delete: if isSignedIn() && (resource.data.instructorId == request.auth.uid || isRole('admin'));

      // Assignments nested under courses
      match /assignments/{assignmentId} {
        allow read: if isSignedIn();
        allow create: if isInstructor(courseId) || isRole('admin');
        allow update, delete: if isInstructor(courseId) || isRole('admin');
      }

      // Modules (weeks) nested under courses
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isInstructor(courseId) || isRole('admin');

        // Sessions nested under modules
        match /sessions/{sessionId} {
            allow read: if isSignedIn();
            allow write: if isInstructor(courseId) || isRole('admin');
        }
      }
    }

    // Enrollments: Students can read their own. Admins/Professors can read all.
    // Students can create their own enrollment. Only Admins can update/delete.
    match /enrollments/{enrollmentId} {
      allow read: if isOneOfRoles(['admin', 'professor']) || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isRole('admin');
    }
    
    // Submissions for assignments
    match /submissions/{submissionId} {
      function getCourseId() {
          return resource.data.courseId;
      }
      function getRequestCourseId() {
          return request.resource.data.courseId;
      }

      allow read: if isSignedIn() && (isOwner(resource.data.studentId) || isInstructor(getCourseId()) || isRole('admin'));
      allow create: if isSignedIn() && isOwner(request.resource.data.studentId);
      allow update: if isSignedIn() && (isOwner(resource.data.studentId) || isInstructor(getRequestCourseId()));
      allow delete: if isSignedIn() && isOwner(resource.data.studentId);
    }

    // Administrative Requests (Trámites)
    match /tramites/{tramiteId} {
      allow read: if isSignedIn() && (isOwner(resource.data.applicantId) || isRole('admin'));
      allow create: if isSignedIn(); // Any signed-in user can create a request
      allow update: if isRole('admin'); // Only admins can update the status/details

      // Updates/History for a request
      match /updates/{updateId} {
        allow read: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/tramites/$(tramiteId)).data.applicantId) || isRole('admin'));
        allow create: if isRole('admin'); // Only admins can add comments/updates
        allow update, delete: if isRole('admin');
      }
    }

    // Payments: Admins can read all. Students can only read their own payments.
    match /payments/{paymentId} {
      allow read: if isRole('admin') || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isRole('admin'); // Only admins can create/update payments
    }

    // Job Offers: Readable by all authenticated users, writable only by admins.
    match /job_offers/{offerId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }

    // Extracurricular Events: Readable by all, writable by admins and professors.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isOneOfRoles(['admin', 'professor']);
    }

    // Wellness Services: Readable by the user and admins. Writable by the user who owns it and admins.
    match /wellness_services/{serviceId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isRole('admin'));
      allow write: if isSignedIn() && (isOwner(request.resource.data.userId) || isRole('admin'));
    }

    // Attendance Records: Writable by professors and admins. Students can read their own records (indirectly).
    // The rule allows direct read for owner/admin/professor for now.
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (isOwner(resource.data.studentId) || isOneOfRoles(['admin', 'professor']));
      allow write: if isOneOfRoles(['admin', 'professor']);
    }
  }
}
