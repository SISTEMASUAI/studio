
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isRole(role) {
      return isSignedIn() && hasProfile() && getProfile().role == role;
    }
    
    function isOneOfRoles(roles) {
      return isSignedIn() && hasProfile() && getProfile().role in roles;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isRole('admin'));
    }

    // Wellness Resources & Config
    match /wellness_resources/{resourceId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }

    match /wellness_service_config/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }

    // Wellness Appointments
    match /wellness_services/{serviceId} {
      allow read: if isSignedIn() && (isRole('admin') || isRole('staff') || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isRole('admin') || isRole('staff') || resource.data.userId == request.auth.uid);
    }

    // Events
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isOneOfRoles(['admin', 'professor']);
    }

    match /activity_enrollments/{enrollmentId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    // Generic match for remaining structures if needed
    match /{document=**} {
      allow read, write: if isRole('admin');
    }
  }
}
